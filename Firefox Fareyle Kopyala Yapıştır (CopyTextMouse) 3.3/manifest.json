{
  "description": "Se\u00e7ili metni fareyle bas\u0131l\u0131 tutuldu\u011funda kopyalar. Fare tekerle\u011fiyle yap\u0131\u015ft\u0131r\u0131r.",
  "manifest_version": 3,
  "name": "Fareyle Kopyala Yap\u0131\u015ft\u0131r (CopyTextMouse)",
  "version": "3.3",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_icon": {
      "128": "copy.png"
    },
    "default_title": "Fareyle Otomatik Kopyala",
    "default_popup": "options.html"
  },
  "icons": {
    "128": "copy.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css",
        "notification.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "Fareyle_Kopyala_Yapistir_CopyTextMouse@tokturbey",
      "strict_min_version": "126.0"
    }
  }
}