{
"update_url": "https://clients2.google.com/service/update2/crx",

  "description": "Seçili metni fareyle basılı tutulduğunda kopyalar. Fare tekerleğiyle yapıştırır.",
  "manifest_version": 3,
  "name": "Fareyle Kopyala Yapıştır (CopyTextMouse)",
  "version": "3.3",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "128": "copy.png"
    },
    "default_title": "Fareyle Otomatik Kopyala",
    "default_popup": "options.html"
  },

  "icons": {
    "128": "copy.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css", "notification.css"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}